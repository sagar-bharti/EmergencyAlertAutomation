<?xml version="1.0" encoding="utf-8"?>
<!--
  AndroidManifest.xml
  Place at: EmergencyApp/android/app/src/main/AndroidManifest.xml

  PERMISSION NOTES:
  - ACCESS_BACKGROUND_LOCATION requires a separate runtime request (Android 10+)
    and Google Play Store review if publishing
  - FOREGROUND_SERVICE_MICROPHONE requires Android 14+ declaration
  - REQUEST_IGNORE_BATTERY_OPTIMIZATIONS lets user whitelist app in battery settings
  - USE_EXACT_ALARM is needed for reliable retry scheduling on Android 12+
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ═══════════════════════════════════════════════════════════════════════
         LOCATION PERMISSIONS
         ACCESS_FINE_LOCATION    – GPS-grade accuracy (required)
         ACCESS_COARSE_LOCATION  – Network-based fallback (required with FINE)
         ACCESS_BACKGROUND_LOCATION – Needed to get location while app is in BG
                                   Requires separate runtime prompt (Android 10+)
                                   Must be requested AFTER foreground location granted
    ═══════════════════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- ═══════════════════════════════════════════════════════════════════════
         SMS PERMISSIONS
         SEND_SMS   – Required for SmsManager.sendTextMessage()
         READ_SMS   – Not required here; avoid requesting unless truly needed
    ═══════════════════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.SEND_SMS" />

    <!-- ═══════════════════════════════════════════════════════════════════════
         CALL PERMISSIONS
         CALL_PHONE       – Places call via ACTION_CALL intent
         READ_PHONE_STATE – Needed to detect call state in some scenarios
    ═══════════════════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- ═══════════════════════════════════════════════════════════════════════
         MICROPHONE – Required for speech recognition
    ═══════════════════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- ═══════════════════════════════════════════════════════════════════════
         FOREGROUND SERVICE
         FOREGROUND_SERVICE                – Base permission for all fg services
         FOREGROUND_SERVICE_LOCATION       – Android 14+: fg service using location
         FOREGROUND_SERVICE_MICROPHONE     – Android 14+: fg service using microphone
    ═══════════════════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- ═══════════════════════════════════════════════════════════════════════
         BOOT & BACKGROUND
         RECEIVE_BOOT_COMPLETED – Restart service after device reboot
         REQUEST_IGNORE_BATTERY_OPTIMIZATIONS – Ask user to whitelist app
         WAKE_LOCK – Keep CPU awake during emergency sequence
    ═══════════════════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- AlarmManager exact alarms for retry scheduling (Android 12+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:minSdkVersion="31" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM"
        android:minSdkVersion="33" />

    <!-- Power button detection -->
    <uses-permission android:name="android.permission.ACTION_SCREEN_ON" />
    <uses-permission android:name="android.permission.ACTION_SCREEN_OFF" />

    <!-- Vibration for alerts -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Internet (for future location API fallback) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Hardware features (not required, only preferred) -->
    <uses-feature android:name="android.hardware.telephony" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />
    <uses-feature android:name="android.hardware.location.gps" android:required="false" />

    <application
        android:name=".MainApplication"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:theme="@style/AppTheme"
        android:requestLegacyExternalStorage="false"
        tools:targetApi="31">

        <!-- ── Main Activity ──────────────────────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:label="@string/app_name"
            android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── EmergencyService (Foreground) ─────────────────────────────── -->
        <!--
            android:foregroundServiceType:
            - "location"    – Accesses GPS in foreground
            - "microphone"  – Uses mic for voice detection
            Both types required on Android 10+
        -->
        <service
            android:name=".EmergencyService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location|microphone"
            android:stopWithTask="false" />
        <!--
            stopWithTask="false" means the service continues even when the
            user swipes away the app from recent tasks. Critical for emergency use.
        -->

        <!-- ── VoiceService (Foreground) ─────────────────────────────────── -->
        <service
            android:name=".VoiceService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="microphone"
            android:stopWithTask="false" />

        <!-- ── BootReceiver – restart services after device reboot ────────── -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <!-- For HTC devices -->
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON"/>
            </intent-filter>
        </receiver>

        <!-- ── PowerButtonReceiver – detect triple power press ───────────── -->
        <!--
            NOTE: Direct power button interception is not possible on Android.
            We detect SCREEN_ON/SCREEN_OFF events as a proxy.
            See PowerButtonReceiver.java for full explanation.
        -->
        <receiver
            android:name=".PowerButtonReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.SCREEN_ON" />
                <action android:name="android.intent.action.SCREEN_OFF" />
                <action android:name="android.intent.action.USER_PRESENT" />
            </intent-filter>
        </receiver>

        <!-- ── SMS Delivery Receiver ─────────────────────────────────────── -->
        <receiver
            android:name=".SmsDeliveryReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="SMS_DELIVERED" />
            </intent-filter>
        </receiver>

        <!-- ── SMS Sent Receiver ──────────────────────────────────────────── -->
        <receiver
            android:name=".SmsSentReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="SMS_SENT" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
